# Copy this file to `.env`, then replace every placeholder with your real production values.
# Never commit or share your real `.env` file.

# Required: token from @BotFather
BOT_TOKEN=enter_bot_token_here

# Comma-separated Telegram user IDs that have admin powers
ADMIN_IDS=111111111,222222222

# Public username of the bot without @. Leave blank to auto-detect at startup.
BOT_USERNAME=enter_bot_username_here

# Branding
SHOP_NAME=Batman Store
SUPPORT_USERNAME=pvtbatman

# Manual deposit destination shown to users. BINANCE_UID is preferred;
# BINANCE_RECEIVING_UID is only a backward-compatible fallback.
BINANCE_UID=526944888
BINANCE_RECEIVING_UID=

# Binance SAPI credentials for automatic Binance Pay / UID-transfer verification.
# BINANCE_API_SECRET is the preferred name. BINANCE_SECRET_KEY is kept for
# backward compatibility with older bot/deposit settings.
BINANCE_API_KEY=enter_binance_api_key_here
BINANCE_API_SECRET=enter_binance_api_secret_here
BINANCE_SECRET_KEY=enter_binance_secret_key_here
BINANCE_API_BASE_URL=https://api.binance.com

# Binance Pay merchant credentials (used to query merchant-created Order IDs)
BINANCE_PAY_API_KEY=enter_binance_pay_identity_key_here
BINANCE_PAY_SECRET_KEY=enter_binance_pay_secret_here
BINANCE_PAY_API_BASE_URL=https://bpay.binanceapi.com
BINANCE_WALLET_ADDRESS=

# BscScan API key for automatic USDT BEP20 transaction-hash verification.
BSCSCAN_API_KEY=enter_bscscan_api_key_here
BSCSCAN_API_BASE_URL=https://api.bscscan.com/api

# Wallet-deposit configuration (also editable in Admin > Deposits)
# BEP20_WALLET_ADDRESS is the primary wallet for deposits and shop payments.
# RECEIVING_WALLET_ADDRESS is only a backward-compatible fallback.
BEP20_WALLET_ADDRESS=0xcdca7abfc27e382c83f0f856839dd3da22efe4db
RECEIVING_WALLET_ADDRESS=
BSC_RPC_URL=https://bsc-dataseed.binance.org
USDT_BEP20_CONTRACT=0x55d398326f99059fF775485246999027B3197955
BEP20_USDT_CONTRACT=0x55d398326f99059fF775485246999027B3197955
DEPOSIT_MIN=1
DEPOSIT_MAX=10000
DEPOSIT_REQUIRED_CONFIRMATIONS=12
DEPOSIT_ALLOWED_WINDOW_MINUTES=60
UID_DEPOSIT_ENABLED=true
ORDER_ID_DEPOSIT_ENABLED=true
BEP20_DEPOSIT_ENABLED=true

# Payment verification safety controls
PAYMENT_REQUIRE_AMOUNT_MATCH=true
PAYMENT_CHECK_DUPLICATE_TXID=true
PAYMENT_LOOKBACK_HOURS=1
PAYMENT_VERIFY_WAIT_SECONDS=60
PAYMENT_VERIFY_INTERVAL_SECONDS=12

# SQLite by default. To switch to Postgres later, use postgresql+asyncpg://...
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db

# Admin web dashboard
# The server always uses 0.0.0.0 and Railway's PORT (default: 8088).
DASHBOARD_PASSWORD=enter_long_random_dashboard_password_here
DASHBOARD_SESSION_SECRET=enter_long_random_session_secret_here

# Withdrawal limits (USDT)
WITHDRAW_MIN=5
WITHDRAW_MAX=1000

# Logging
LOG_LEVEL=INFO

# Render premium custom emojis as button icons via Bot API 9.4.
# Set to false to fall back to plain unicode glyphs in button labels.
PREMIUM_BUTTON_ICONS=true

# Apply Bot API 9.4 button colours (`style`: primary / success / danger).
# Set to false for the client's default button colour everywhere.
BUTTON_STYLES_ENABLED=true
